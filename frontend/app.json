{
  "expo": {
    "name": "BUMP",
    "slug": "bump",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bump",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find nightlife venues near you",
        "NSCameraUsageDescription": "Take a live selfie to check in"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#030305"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#030305"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find nightlife venues near you"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Take a live selfie to check in to venues"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
